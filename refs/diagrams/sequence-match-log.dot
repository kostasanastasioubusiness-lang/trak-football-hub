// Primary Flow: Player logs a match (end-to-end)
// Read top-to-bottom as a sequence diagram

digraph match_log_sequence {
    rankdir=TB;
    fontname="DM Sans";
    node [fontname="DM Sans", shape=box, style="rounded,filled", fillcolor="#17171A", fontcolor="#e0e0e0", color="#333"];
    edge [fontname="DM Sans", fontsize=9, color="#666", fontcolor="#999"];
    bgcolor="#0A0A0B";

    // Actors
    Player [label="Player", shape=ellipse, fillcolor="#202024"];
    FormUI [label="Match Log Form\n(s-p-logform)"];
    RatingEng [label="Rating Engine\n(client-side)"];
    SupaClient [label="Supabase Client"];
    DB [label="PostgreSQL", shape=cylinder, fillcolor="#202024"];
    MedalChk [label="Medal Checker"];
    GoalUpd [label="Goal Updater"];
    Telemetry [label="Telemetry Logger"];
    ResultUI [label="Result Screen\n(s-p-result)"];

    // Sequence
    Player -> FormUI [label="1. Opens form"];
    FormUI -> Telemetry [label="2. fire(form_start)"];
    Telemetry -> DB [label="3. INSERT telemetry_events"];

    Player -> FormUI [label="4. Fills fields\n(each change)"];
    FormUI -> RatingEng [label="5. computeScore(inputs)"];
    RatingEng -> FormUI [label="6. { score, band }\n(preview only)"];

    Player -> FormUI [label="7. Taps Save"];
    FormUI -> RatingEng [label="8. computeScore(inputs)\n(final)"];
    RatingEng -> FormUI [label="9. { score, band }"];
    FormUI -> SupaClient [label="10. INSERT match\n(all fields + score + band)"];
    SupaClient -> DB [label="11. INSERT INTO matches\n(RLS: player owns row)"];
    DB -> SupaClient [label="12. OK + match row"];

    SupaClient -> Telemetry [label="13. fire(form_submit\n+ match_log)"];
    Telemetry -> DB [label="14. INSERT telemetry x2"];

    SupaClient -> GoalUpd [label="15. checkAutoGoals(match)"];
    GoalUpd -> DB [label="16. SELECT active goals\nUPDATE current_number"];

    SupaClient -> MedalChk [label="17. checkMedals(player_id)"];
    MedalChk -> DB [label="18. SELECT match history\nSELECT existing medals"];
    MedalChk -> DB [label="19. INSERT medal\n(if newly earned)"];

    SupaClient -> ResultUI [label="20. Navigate with\n{ match, newGoals, newMedals }"];
    ResultUI -> Player [label="21. Band reveal\n+ goal/medal cards"];
}
