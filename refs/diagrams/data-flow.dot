digraph trak_data_flow {
    rankdir=LR;
    fontname="DM Sans";
    node [fontname="DM Sans", fontsize=11, color="#333", fontcolor="#e0e0e0"];
    edge [fontname="DM Sans", fontsize=9, color="#666", fontcolor="#999"];
    bgcolor="#0A0A0B";

    // ──── Inputs ────
    subgraph cluster_inputs {
        label="Inputs";
        style="rounded,dashed";
        color="#444";
        fontcolor="#C8F25A";

        MatchInputs [label="Match Form Fields\n(opponent, score, mins,\ncard, body, self-rating,\nposition inputs)", shape=parallelogram, style="filled", fillcolor="#202024"];
        CoachInputs [label="Assessment Sliders\n(6 categories x 1-10)", shape=parallelogram, style="filled", fillcolor="#202024"];
        InviteCode [label="Invite Code Entry\n(TRK-XXXX / PAR-XXXX)", shape=parallelogram, style="filled", fillcolor="#202024"];
        GoalInput [label="Goal Progress\n(manual update)", shape=parallelogram, style="filled", fillcolor="#202024"];
    }

    // ──── Transforms ────
    subgraph cluster_transforms {
        label="Transforms (Client-Side)";
        style="rounded,dashed";
        color="#444";
        fontcolor="#C8F25A";

        RatingCalc [label="Rating Algorithm\n6.5 baseline\n+ modifiers\nx0.8 if friendly\nclamp 4.0–10.0", shape=box, style="rounded,filled", fillcolor="#17171A"];
        BandMap [label="Score → Band\nMapping\n(7 thresholds)", shape=box, style="rounded,filled", fillcolor="#17171A"];
        CoachBandCalc [label="Average 6 Scores\n→ Band Mapping", shape=box, style="rounded,filled", fillcolor="#17171A"];
        MedalLogic [label="Medal Trigger\nChecks\n(6 conditions)", shape=box, style="rounded,filled", fillcolor="#17171A"];
        GoalAutoCalc [label="Auto-Goal\nIncrement\n(3 tracking fields)", shape=box, style="rounded,filled", fillcolor="#17171A"];
        CodeValidator [label="Code Lookup\n+ Validation", shape=box, style="rounded,filled", fillcolor="#17171A"];
        ParentFilter [label="Column Filter\n(hide private fields\nfrom parent role)", shape=box, style="rounded,filled", fillcolor="#17171A"];
    }

    // ──── Stores ────
    subgraph cluster_stores {
        label="Stores (Supabase PostgreSQL)";
        style="rounded,dashed";
        color="#444";
        fontcolor="#C8F25A";

        MatchesTable [label="matches\n(computed_score,\nband, all inputs)", shape=cylinder, style="filled", fillcolor="#202024"];
        AssessTable [label="assessments\n(6 scores,\noverall_band)", shape=cylinder, style="filled", fillcolor="#202024"];
        GoalsTable [label="goals\n(current_number,\nprogress_level)", shape=cylinder, style="filled", fillcolor="#202024"];
        MedalsTable [label="medals\n(medal_type,\nunlocked_at)", shape=cylinder, style="filled", fillcolor="#202024"];
        ConnTable [label="player_coach\nplayer_parent", shape=cylinder, style="filled", fillcolor="#202024"];
        TelemetryTable [label="telemetry_events\n(event_type,\nmetadata)", shape=cylinder, style="filled", fillcolor="#202024"];
    }

    // ──── Outputs ────
    subgraph cluster_outputs {
        label="Outputs (UI)";
        style="rounded,dashed";
        color="#444";
        fontcolor="#C8F25A";

        LivePreview [label="Live Band Preview\n(form footer)", shape=parallelogram, style="filled", fillcolor="#202024"];
        BandReveal [label="Band Reveal\n(result screen)", shape=parallelogram, style="filled", fillcolor="#202024"];
        PlayerHome [label="Player Home\n(distribution bars,\ntrend, recent)", shape=parallelogram, style="filled", fillcolor="#202024"];
        CoachSquad [label="Coach Squad\n(player list +\nband pills)", shape=parallelogram, style="filled", fillcolor="#202024"];
        ParentView [label="Parent Home\n(band, assessments,\ngoals — filtered)", shape=parallelogram, style="filled", fillcolor="#202024"];
        MedalCard [label="Medal Unlock\n(result screen)", shape=parallelogram, style="filled", fillcolor="#202024"];
        GoalProgress [label="Goal Update\n(result screen)", shape=parallelogram, style="filled", fillcolor="#202024"];
        PilotDash [label="Pilot Dashboard\n(SQL views,\nfounder only)", shape=parallelogram, style="filled", fillcolor="#202024"];
    }

    // ──── Edges ────
    MatchInputs -> RatingCalc;
    RatingCalc -> BandMap;
    BandMap -> LivePreview [label="on each\nfield change"];
    BandMap -> MatchesTable [label="on save"];
    MatchesTable -> GoalAutoCalc;
    MatchesTable -> MedalLogic;
    GoalAutoCalc -> GoalsTable;
    MedalLogic -> MedalsTable;

    CoachInputs -> CoachBandCalc;
    CoachBandCalc -> AssessTable;

    InviteCode -> CodeValidator;
    CodeValidator -> ConnTable;

    GoalInput -> GoalsTable;

    MatchesTable -> PlayerHome;
    MatchesTable -> CoachSquad;
    MatchesTable -> ParentFilter;
    AssessTable -> ParentFilter;
    ParentFilter -> ParentView;
    MedalsTable -> MedalCard;
    GoalsTable -> GoalProgress;
    TelemetryTable -> PilotDash;

    MatchesTable -> BandReveal [label="after save"];
}
