digraph trak_components {
    rankdir=TB;
    fontname="DM Sans";
    node [fontname="DM Sans", shape=box, style="rounded,filled", fillcolor="#17171A", fontcolor="#e0e0e0", color="#333"];
    edge [fontname="DM Sans", fontsize=10, color="#666", fontcolor="#999"];
    bgcolor="#0A0A0B";

    // ──── Frontend Layer ────
    subgraph cluster_frontend {
        label="React App (Mobile Web, max 430px)";
        labeljust=l;
        style="rounded,dashed";
        color="#333";
        fontcolor="#C8F25A";

        subgraph cluster_auth {
            label="Auth";
            style="rounded";
            color="#444";
            fontcolor="#86efac";
            Landing [label="Landing\n(Role Select)"];
            AuthForms [label="Signup / Login\n(Supabase Auth)"];
            RouteGuard [label="Route Guard\n(Role + Onboarding)"];
        }

        subgraph cluster_player {
            label="Player Screens";
            style="rounded";
            color="#444";
            fontcolor="#86efac";
            POnboard [label="Onboarding\n(4 steps)"];
            PHome [label="Home\n(Hero + Distribution)"];
            PMatchLog [label="Match Log Form\n+ Live Preview"];
            PResult [label="Result Screen\n(Band Reveal)"];
            PMatches [label="Match History\n+ Detail"];
            PGoals [label="Goals\n(Auto + Manual)"];
            PMedals [label="Medals\n(6 slots)"];
            PProfile [label="Profile"];
        }

        subgraph cluster_coach {
            label="Coach Screens";
            style="rounded";
            color="#444";
            fontcolor="#86efac";
            COnboard [label="Onboarding\n(2 steps)"];
            CHome [label="Home"];
            CSquad [label="Squad\nManagement"];
            CAssess [label="Assessment Form\n(6 Sliders)"];
            CSessions [label="Sessions\n(Log + List)"];
            CInvite [label="Invite Code\n(TRK-XXXX)"];
            CProfile [label="Coach Profile"];
        }

        subgraph cluster_parent {
            label="Parent Screens";
            style="rounded";
            color="#444";
            fontcolor="#86efac";
            ParOnboard [label="Onboarding\n(PAR-XXXX)"];
            ParHome [label="Home\n(Child Hero)"];
            ParMatches [label="Match Feed\n(Filtered)"];
            ParGoals [label="Goals\n(Read-Only)"];
            ParAlerts [label="Alerts\n(3 Types)"];
        }

        subgraph cluster_shared {
            label="Shared";
            style="rounded";
            color="#444";
            fontcolor="#86efac";
            RatingEngine [label="Rating Engine\n(computeScore\n+ scoreToBand)"];
            MedalChecker [label="Medal Checker\n(6 triggers)"];
            GoalUpdater [label="Goal Updater\n(auto-track)"];
            TelemetryClient [label="Telemetry\n(event logger)"];
            Components [label="Component Library\n(BandPill, NavBar,\nCard, Slider, etc.)"];
        }
    }

    // ──── Supabase Layer ────
    subgraph cluster_supabase {
        label="Supabase (Frankfurt)";
        labeljust=l;
        style="rounded,dashed";
        color="#333";
        fontcolor="#C8F25A";

        SupaAuth [label="Supabase Auth\n(Email + Confirm)", fillcolor="#202024"];
        SupaDB [label="PostgreSQL\n(10 tables + views)", shape=cylinder, fillcolor="#202024"];
        SupaRLS [label="RLS Policies\n(Row-Level Security)", fillcolor="#202024"];
        SupaStorage [label="Realtime\n(not used in pilot)", style="rounded,dashed,filled", fillcolor="#101012"];
    }

    // ──── External ────
    subgraph cluster_external {
        label="External";
        labeljust=l;
        style="rounded,dashed";
        color="#333";
        fontcolor="#C8F25A";

        Resend [label="Resend SMTP\n(Email Confirm)", fillcolor="#202024"];
    }

    // ──── Connections ────
    Landing -> AuthForms;
    AuthForms -> SupaAuth [label="signup/login"];
    SupaAuth -> Resend [label="confirmation email"];
    SupaAuth -> RouteGuard [label="session token"];

    RouteGuard -> POnboard [label="player, incomplete"];
    RouteGuard -> PHome [label="player, complete"];
    RouteGuard -> COnboard [label="coach, incomplete"];
    RouteGuard -> CHome [label="coach, complete"];
    RouteGuard -> ParOnboard [label="parent, incomplete"];
    RouteGuard -> ParHome [label="parent, complete"];

    PMatchLog -> RatingEngine [label="field change"];
    PMatchLog -> SupaDB [label="INSERT match"];
    PMatchLog -> TelemetryClient [label="form_start\nform_submit"];
    PMatchLog -> MedalChecker [label="after save"];
    PMatchLog -> GoalUpdater [label="after save"];

    CAssess -> SupaDB [label="INSERT assessment"];
    CAssess -> TelemetryClient [label="assessment"];

    ParHome -> SupaDB [label="SELECT\n(RLS filtered)"];
    ParHome -> TelemetryClient [label="parent_open"];

    TelemetryClient -> SupaDB [label="INSERT\ntelemetry_events"];
    MedalChecker -> SupaDB [label="INSERT medals\n(if earned)"];
    GoalUpdater -> SupaDB [label="UPDATE goals\n(auto-tracked)"];

    SupaDB -> SupaRLS [label="enforces", style=dotted];
}
